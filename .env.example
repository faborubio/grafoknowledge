# Copiar a .env y completar. Las keys NUNCA van al cliente ni al repo (ADR del SAD).

# LLM — extracción, adjudicación de entidades, redacción de respuestas
ANTHROPIC_API_KEY=

# Embeddings — resolución de entidades
GEMINI_API_KEY=
# Modelo de embeddings PINEADO (cambiarlo invalida el índice vectorial — ver riesgos del SAD)
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIM=768

# Neo4j (docker-compose local por defecto)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=grafoknowledge-dev

# Backend
PORT=3001
